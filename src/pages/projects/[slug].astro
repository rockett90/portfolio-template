---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { site } from '../../site.config';
import 'katex/dist/katex.min.css';

export async function getStaticPaths() {
  const projects = await getCollection('projects', e => !e.data.draft);
  return projects.map(p => ({ params: { slug: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content, headings } = await render(project);

// Auto table of contents — show when there are at least 3 top-level sections.
const toc = headings.filter(h => h.depth >= 2 && h.depth <= 3);
const showToc = headings.filter(h => h.depth === 2).length >= 3;

const typeBadge: Record<string,string> = {
  wip:'badge-wip', build:'badge-build', guide:'badge-guide', document:'badge-document',
};
const typeLabel: Record<string,string> = {
  wip:'In progress', build:'Build log', guide:'Guide', document:'Document',
};

const words = (project.body ?? '').trim().split(/\s+/).filter(Boolean).length;
const readMins = Math.max(1, Math.round(words / 200));
---
<Base title={`${project.data.title} — ${site.name}`} description={project.data.description}>
  <div class="wrap">
    <a class="reading-back" href="/#projects">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
      Back to projects
    </a>
    <article class="reading">
      <div class="article-meta">
        <span class={`type-badge ${typeBadge[project.data.type]}`}>{typeLabel[project.data.type]}</span>
        <span class="dim">{project.data.date}</span>
        <span class="dim">{readMins} min read</span>
      </div>
      <h1 class="article-title">{project.data.title}</h1>
      <p class="article-lead">{project.data.description}</p>
      <div class="article-tags">{project.data.tags.map(t => <span class="chip">{t}</span>)}</div>
      {(project.data.repo || project.data.youtube) && (
        <div class="article-links">
          {project.data.repo && <a class="link-pill" href={project.data.repo} target="_blank" rel="noopener">GitHub repo →</a>}
          {project.data.youtube && <a class="link-pill" href={project.data.youtube} target="_blank" rel="noopener">Watch on YouTube →</a>}
        </div>
      )}
      <hr class="article-rule">
      {showToc && (
        <details class="toc" open>
          <summary>Contents</summary>
          <ul>
            {toc.map(h => <li class={`toc-d${h.depth}`}><a href={`#${h.slug}`}>{h.text}</a></li>)}
          </ul>
        </details>
      )}
      <div class="prose"><Content /></div>
    </article>
  </div>
</Base>
