---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';
import { site } from '../../site.config';

export async function getStaticPaths() {
  // Only resources without a file *and* without an external url get a page.
  const resources = await getCollection('resources', e => !e.data.draft && !e.data.file && !e.data.url);
  return resources.map(r => ({ params: { slug: r.id }, props: { resource: r } }));
}

const { resource } = Astro.props;
const { Content } = await render(resource);

const typeBadge: Record<string,string> = {
  template:'badge-template', checklist:'badge-checklist', guide:'badge-guide', config:'badge-config',
};
---
<Base title={`${resource.data.title} — ${site.name}`} description={resource.data.description}>
<style>
  .res-hero { padding: 48px 0 40px; }
  .back { font-family: var(--mono); font-size: 0.72rem; color: var(--muted); text-decoration: none; display: inline-flex; align-items: center; gap: 5px; margin-bottom: 28px; transition: color 0.2s; }
  .back:hover { color: var(--text); }
  .back svg { width: 13px; height: 13px; }
  .res-meta { display: flex; align-items: center; gap: 12px; margin-bottom: 18px; }
  .res-updated { font-family: var(--mono); font-size: 0.7rem; color: var(--muted); }
  .res-title { font-family: var(--serif); font-size: clamp(2rem, 4vw, 3.2rem); letter-spacing: -0.8px; line-height: 1.06; margin-bottom: 16px; }
  .res-lead  { font-size: 1.05rem; color: var(--muted); font-weight: 300; line-height: 1.8; max-width: 620px; margin-bottom: 28px; }
  .res-tags  { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 48px; }
  .res-body  { max-width: 720px; padding-bottom: 80px; }
  .res-body :global(h2) { font-family: var(--serif); font-size: 1.8rem; letter-spacing: -0.3px; margin: 44px 0 14px; padding-top: 44px; border-top: 1px solid var(--border); }
  .res-body :global(h2:first-child) { margin-top: 0; padding-top: 0; border-top: none; }
  .res-body :global(h3) { font-size: 1rem; font-weight: 500; margin: 24px 0 8px; }
  .res-body :global(p)  { font-size: 0.96rem; color: var(--muted); line-height: 1.85; margin-bottom: 16px; font-weight: 300; }
  .res-body :global(strong) { color: var(--text); font-weight: 500; }
  .res-body :global(a)  { color: var(--accent); }
  .res-body :global(ul), .res-body :global(ol) { padding-left: 1.4rem; margin-bottom: 16px; }
  .res-body :global(li) { font-size: 0.96rem; color: var(--muted); line-height: 1.85; margin-bottom: 6px; font-weight: 300; }
  .res-body :global(pre) { background: var(--surface); border: 1px solid var(--border); border-radius: 10px; padding: 20px; overflow-x: auto; margin: 20px 0; }
  .res-body :global(code) { font-family: var(--mono); font-size: 0.82rem; }
  .res-body :global(p code) { background: var(--surface); border: 1px solid var(--border); border-radius: 4px; padding: 1px 6px; font-size: 0.83em; }
  .res-body :global(img) { width: 100%; border-radius: 12px; border: 1px solid var(--border); margin: 20px 0; display: block; }
  .res-body :global(table) { width: 100%; border-collapse: collapse; margin: 20px 0; font-size: 0.88rem; }
  .res-body :global(th) { font-family: var(--mono); font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.06em; color: var(--muted); text-align: left; padding: 10px 14px; border-bottom: 2px solid var(--border); }
  .res-body :global(td) { padding: 10px 14px; border-bottom: 1px solid var(--border); color: var(--text); }
</style>
  <div class="wrap">
    <div class="res-hero">
      <a class="back" href="/#resources">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
        Back to resources
      </a>
      <div class="res-meta">
        <span class={`type-badge ${typeBadge[resource.data.type]}`}>{resource.data.type}</span>
        <span class="res-updated">Updated {resource.data.updated}</span>
      </div>
      <div class="res-title">{resource.data.title}</div>
      <p class="res-lead">{resource.data.description}</p>
      <div class="res-tags">{resource.data.tags.map(t => <span class="chip">{t}</span>)}</div>
    </div>
    <hr>
    <div class="res-body"><Content /></div>
  </div>
</Base>
